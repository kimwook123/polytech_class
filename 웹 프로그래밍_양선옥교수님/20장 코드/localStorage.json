{
  "상품목록": {
    "저장방법": "localStorage.setItem('products', JSON.stringify(products))",
    "불러오는방법": "JSON.parse(localStorage.getItem('products'))",
    "데이터": [
      {
        "id": 1,
        "name": "노트북",
        "price": 1200000
      },
      {
        "id": 2,
        "name": "마우스",
        "price": 30000
      },
      {
        "id": 3,
        "name": "키보드",
        "price": 80000
      }
    ]
  },
  "배열메서드": {
    "find": {
      "설명": "조건에 맞는 첫 번째 요소 반환",
      "문법": "배열.find(콜백함수)",
      "예제": "products.find(p => p.id === 2)",
      "결과": {
        "id": 2,
        "name": "마우스",
        "price": 30000
      }
    },
    "filter": {
      "설명": "조건에 맞는 모든 요소를 새 배열로 반환",
      "문법": "배열.filter(콜백함수)",
      "예제": "products.filter(p => p.price >= 50000)",
      "결과": [
        {
          "id": 2,
          "name": "마우스",
          "price": 30000
        }
      ]
    },
    "map": {
      "설명": "배열의 각 요소를 변환하여 새 배열로 반환",
      "문법": "배열.map(콜백함수)",
      "예제": "products.map(p => p.name)",
      "결과": [
        "노트북",
        "마우스",
        "키보드"
      ]
    },
    "forEach": {
      "설명": "배열의 각 요소에 대해 함수 실행 (반환값 없음)",
      "문법": "배열.forEach(콜백함수)",
      "예제": "products.forEach((p, index) => console.log(index, p.name))"
    },
    "reduce": {
      "설명": "배열의 각 요소를 순회하며 하나의 값으로 축약",
      "문법": "배열.reduce(콜백함수, 초기값)",
      "예제": "products.reduce((sum, p) => sum + p.price, 0)",
      "결과": 1310000,
      "설명_결과": "모든 상품의 가격 합계"
    },
    "some": {
      "설명": "조건에 맞는 요소가 하나라도 있으면 true 반환",
      "문법": "배열.some(콜백함수)",
      "예제": "products.some(p => p.price > 500000)",
      "결과": true
    },
    "every": {
      "설명": "모든 요소가 조건을 만족하면 true 반환",
      "문법": "배열.every(콜백함수)",
      "예제": "products.every(p => p.price > 0)",
      "결과": true
    }
  },
  "localStorage_주의사항": [
    "저장할 때는 JSON.stringify() 사용",
    "불러올 때는 JSON.parse() 사용",
